{
    "window.commandCenter": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.vscode": true,
        "**/.zed": true,
        "**/.cursor": true,
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/*.pyc": true,
        "**/node_modules": true,
        "**/.venv/": true
    },
    "search.exclude": {
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.vscode": true,
        "**/.zed": true,
        "**/.cursor": true,
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/*.pyc": true,
        "**/node_modules": true,
        "**/.venv/": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/htmlcov": true,
        "static/": true,
        "media_root/": true,
        "logs/": true,
        "frontend/dist/": true,
        "storybook/storybook-static/": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/static/**": true,
        "**/media_root/**": true,
        "**/logs/**": true,
        "**/htmlcov/**": true,
        "**/__pycache__/**": true,
        "**/.mypy_cache/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/frontend/dist/**": true
    },
    "diffEditor.useInlineViewWhenSpaceIsLimited": false,
    "terminal.integrated.scrollback": 100000,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "explorer.confirmDragAndDrop": false,
    "workbench.editorAssociations": {
        "git-rebase-todo": "default"
    },
    "workbench.colorTheme": "Spacegray Ocean Dark",
    "workbench.editor.enablePreview": false,
    "security.promptForLocalFileProtocolHandling": false,
    "explorer.confirmDelete": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.multiCursorLimit": 20000,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.multiCursorMergeOverlapping": false,
    "editor.suggest.showStatusBar": true,
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 10,
    "terminal.integrated.fontFamily": "JetBrains Mono",
    "terminal.integrated.fontSize": 11,
    "git.mergeEditor": false,
    "workbench.tree.indent": 16,
    "gitlens.views.branches.branches.layout": "list",
    "claudeCode.preferredLocation": "panel",
    "merge-conflict.decorators.enabled": true,
    "merge-conflict.codeLens.enabled": true,
    "workbench.startupEditor": "welcomePage",
    "editor.minimap.enabled": true,
    "workbench.iconTheme": "vscode-jetbrains-icon-theme",
    "window.titleBarStyle": "custom",
    "gitlens.currentLine.enabled": true,
    "claudeCode.selectedModel": "opus[1m]",
    "containers.containerClient": "com.microsoft.visualstudio.containers.podman",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.podmancompose",
    "githubPullRequests.pullBranch": "never",
    "window.autoDetectColorScheme": false,
    "[json]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
    }
}
