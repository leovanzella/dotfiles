// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "search": {
    "include_ignored": false
  },
  "buffer_font_weight": 400.0,
  "format_on_save": "off",
  "session": {
    "trust_all_worktrees": true
  },
  "preview_tabs": {
    "enabled": false
  },
  "minimap": {
    "show": "always"
  },
  "base_keymap": "VSCode",
  "diff_view_style": "split",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Frappé"
  },
  "project_panel": {
    "sort_order": "default",
    "hide_root": false,
    "git_status_indicator": true,
    "bold_folder_labels": false,
    "indent_size": 20.0,
    "entry_spacing": "comfortable",
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "git_panel": {
    "entry_primary_click_action": "file_diff",
    "button": true,
    "scrollbar": {
      "show": "auto"
    },
    "diff_stats": true,
    "folder_icons": true,
    "file_icons": true,
    "collapse_untracked_diff": false,
    "status_style": "icon",
    "default_width": 360.0,
    "show_count_badge": true,
    "tree_view": true,
    "dock": "left"
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Spacegray Ocean"
  },
  "agent": {
    "flexible": true,
    "button": true,
    "dock": "right",
    "play_sound_when_agent_done": "always",
  },
  // "icon_theme": "Material Icon Theme",
  "vim_mode": true,
  "ui_font_size": 15,
  "buffer_font_family": "Consolas",
  "buffer_font_size": 12.0,
  "terminal": {
    "shell": {
      "program": "zsh"
    },
    "show_count_badge": true,
    "max_scroll_history_lines": 100000,
    "font_family": "JetBrains Mono",
    "font_size": 11.0,
    "env": {
      "EDITOR": "zed --wait",
    },
  },
  "show_completions_on_input": true,
  "file_scan_exclusions": [
    ".claude",
    ".cursor",
    ".git",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    ".vscode",
    "__pycache__",
    "node_modules",
    ".DS_Store",
  ]
}
